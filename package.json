{
	"name": "@clera/trigger-cli",
	"version": "1.0.0",
	"description": "CLI for the Trigger.dev Management REST API",
	"type": "module",
	"bin": {
		"trigger-cli": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean",
		"dev": "tsx src/index.ts",
		"start": "node dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"chalk": "^5.4.1",
		"commander": "^12.1.0",
		"dotenv": "^16.4.7"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT"
}
